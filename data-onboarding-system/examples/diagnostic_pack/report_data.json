  "kpis": [
    {
      "name": "Average Order Value (AOV)",
      "category": "Revenue",
      "priority": 1,
      "description": "Average revenue per order",
      "required_tables": [
        "orders"
      ],
      "required_columns": [
        "order_total",
        "order_id"
      ],
      "sql_template": "SELECT \n  AVG(order_total) as aov,\n  DATE_TRUNC('month', order_date) as month\nFROM orders\nWHERE order_date >= CURRENT_DATE - INTERVAL '12 months'\nGROUP BY month\nORDER BY month DESC\n",
